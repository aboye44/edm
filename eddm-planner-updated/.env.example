# ─────────────────────────────────────────────────────────────
# Client-side environment variables (React — must be REACT_APP_* prefix)
# ─────────────────────────────────────────────────────────────

# Google Maps API Key
# Get your key from: https://console.cloud.google.com/apis/credentials
# Enable these APIs: Maps JavaScript API, Places API
REACT_APP_GOOGLE_MAPS_API_KEY=your_api_key_here

# Optional — v1 webhook for production /-route quote submissions.
# Leave unset to use localStorage fallback (see WEBHOOK_SETUP.md).
REACT_APP_ZAPIER_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────
# Server-side environment variables (Netlify Functions only — no prefix)
# ─────────────────────────────────────────────────────────────

# SendGrid powers the /v2 Step 3 quote-submit flow
# (netlify/functions/submit-quote-request.js). The function returns HTTP
# 500 with a clear message if SENDGRID_API_KEY is missing — it will NOT
# silently drop submissions.
#
# Set these on Netlify (Site settings → Environment variables) AND on
# Vercel if the same repo deploys there (Project settings → Environment
# Variables).

# REQUIRED — SendGrid API key with "Mail Send" permission.
# Generate at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — Verified sender address. Must be authenticated in SendGrid
# (sender verification OR domain authentication) or sends will 403.
# Defaults to orders@mailpro.org when unset.
SENDGRID_FROM_EMAIL=orders@mailpro.org

# OPTIONAL — Internal inbox that receives the quote request. Defaults
# to orders@mailpro.org when unset.
SENDGRID_TO_EMAIL=orders@mailpro.org
