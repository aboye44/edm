# ─────────────────────────────────────────────────────────────
# Client-side environment variables (React — must be REACT_APP_* prefix)
# ─────────────────────────────────────────────────────────────

# Google Maps API Key
# Get your key from: https://console.cloud.google.com/apis/credentials
# Enable these APIs: Maps JavaScript API, Places API
REACT_APP_GOOGLE_MAPS_API_KEY=your_api_key_here

# Optional — v1 webhook for production /-route quote submissions.
# Leave unset to use localStorage fallback (see WEBHOOK_SETUP.md).
REACT_APP_ZAPIER_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────
# Server-side environment variables (Netlify Functions only — no prefix)
# ─────────────────────────────────────────────────────────────

# Used by netlify/functions/submit-quote-request.js for the /v2 Step 3 flow.
# The function refuses to start without AIRTABLE_API_KEY and AIRTABLE_BASE_ID
# and logs a warning — it will NOT silently drop submissions.
#
# Set these on Netlify:
#   Site settings → Environment variables → Add variable
# (If this repo also deploys to Vercel, set the same three there under
#  Project settings → Environment Variables.)
AIRTABLE_API_KEY=your_personal_access_token_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Quote Requests
