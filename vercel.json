{
  "buildCommand": "cd eddm-planner-updated && npm install && npm run build",
  "outputDirectory": "eddm-planner-updated/build",
  "installCommand": "cd eddm-planner-updated && npm install",
  "framework": "create-react-app",
  "rewrites": [
    {
      "source": "/.netlify/functions/eddm-routes",
      "destination": "/api/eddm-routes"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "eddm.mailpro.org" }],
      "destination": "https://www.mailpro.org/eddm/$1",
      "permanent": true
    }
  ]
}
